{
  "name": "donation-auth-module",
  "version": "1.0.0",
  "description": "User Authentication and Authorization module for an Online Donation System",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
